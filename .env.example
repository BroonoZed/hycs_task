# Telegram
BOT_TOKEN=

# 群聊采集范围（英文逗号分隔）
SUPPORT_GROUP_IDS=-1001111111111,-1002222222222

# 任务汇总频道（你给定）
TASK_CHANNEL_ID=-1003892387186

# 可执行管理命令的账号
ADMIN_TG_IDS=7611295576

# 超时 SLA（分钟）
TASK_SLA_MINUTES=10

# 关键词：用于判定“疑似客服问题”
QUESTION_KEYWORDS=订单,查单,没到账,未到账,怎么,如何,失败,异常,卡单,支付,退款,催,多久
NOISE_KEYWORDS=收到,好的,ok,thanks,谢谢,已处理
NOISE_IGNORE_USER_IDS=

# 任务卡片快捷回复规则（触发词:快捷语key，用 | 分隔）
TASK_QR_RULES=未到账:ask_order|退款:refund_flow|可以处理吗:processing

# SQLite 本地库
SQLITE_PATH=tasks.db

# 方案B（推荐）：通过 hybot 内部 API 查单
ORDER_API_URL=
ORDER_API_TOKEN=
ORDER_API_TIMEOUT=8

# 备选：直连 PostgreSQL（方案A/C）
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSLMODE=prefer
DB_CONNECT_TIMEOUT=8
